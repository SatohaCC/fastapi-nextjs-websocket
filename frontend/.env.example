# Frontend environment variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and loaded automatically by Next.js.

# --- BFF Session Encryption ---
# Must be exactly 32 bytes (or longer; the key is SHA-256 hashed internally).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BFF_SECRET=CHANGE_ME_generate_a_secure_random_key

# --- Backend API URLs ---
# Exposed to the browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

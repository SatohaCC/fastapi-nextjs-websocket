# 使い方:
#   1. このファイルを secret.yaml にコピーする（secret.yaml は .gitignore 済み）
#      cp k8s/secret.yaml.example k8s/secret.yaml
#   2. <change-me> をすべて実際の値に置き換える
#      鍵類は `openssl rand -hex 32` で生成すること
#   3. kubectl apply -f k8s/secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
type: Opaque
stringData:
  POSTGRES_PASSWORD: "<change-me>"
  # パスワード部分は POSTGRES_PASSWORD と一致させること
  DATABASE_URL: "postgresql+asyncpg://user:<change-me>@postgres:5432/chat_db"
  # openssl rand -hex 32
  SECRET_KEY: "<change-me>"
  ADMIN_PASSWORD: "<change-me>"
  # openssl rand -hex 32
  ADMIN_SECRET_KEY: "<change-me>"
  # ログイン可能なユーザーの定義 (JSON)
  USERS: '{"<username>": "<password>"}'

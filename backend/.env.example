# Backend environment variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and loaded automatically by pydantic-settings.

# --- Environment ---
# "development" (default) or "production"
# In production, all secrets below must be set to non-default values.
APP_ENV=development

# --- CORS ---
ALLOWED_ORIGIN=http://localhost:3000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/chat_db

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_secure_random_key

# --- SQLAdmin ---
ADMIN_USERNAME=admin
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
ADMIN_PASSWORD=CHANGE_ME_secure_admin_password
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET_KEY=CHANGE_ME_generate_a_secure_random_key

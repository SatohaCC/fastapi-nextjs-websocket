# Root-level environment variables for Docker Compose
# Copy this file to .env.local, fill in the values, then start with:
#   docker compose --env-file .env.local up
# (Docker Compose only auto-loads a file named exactly ".env";
#  .env.local must be passed explicitly via --env-file.)

# --- PostgreSQL ---
POSTGRES_USER=user
POSTGRES_PASSWORD=CHANGE_ME_secure_db_password
POSTGRES_DB=chat_db

# --- pgAdmin ---
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=CHANGE_ME_pgadmin_password

# --- Backend ---
ALLOWED_ORIGIN=http://localhost:3000
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_secure_random_key
APP_ENV=development
